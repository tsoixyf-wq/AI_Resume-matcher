# 后端 API 的主机地址（供 Next.js rewrite 代理使用）
# ──────────────────────────────────────────────
# 本地开发 (后端在宿主机):       localhost
# Docker 开发 (同 compose 网络): backend
# 生产部署 (Vercel):             由 vercel.json 中的 NEXT_PUBLIC_API_URL 覆盖
# 生产部署 (Docker):             backend
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_HOST=localhost

# 前端开发服务器端口
PORT=3000
